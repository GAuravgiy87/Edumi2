# =============================================================================
#  EduMi — .gitignore
# =============================================================================

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/
MANIFEST

# ── Django ────────────────────────────────────────────────────────────────────
db.sqlite3
db.sqlite3-journal
*.sqlite3

# Collected static files (generated by collectstatic)
staticfiles/

# Django cache framework files
cache/
.cache/

# Media uploads (user content — not for version control)
media/

# Local settings override
local_settings.py
school_project/local_settings.py

# ── Environment & Secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.cert
*.crt
secrets/

# ── Virtual Environments ──────────────────────────────────────────────────────
venv/
env/
.venv/
ENV/
.python-version

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
*.log.*

# ── Celery ────────────────────────────────────────────────────────────────────
celerybeat-schedule
celerybeat-schedule.db
celerybeat.pid

# ── Redis dump ────────────────────────────────────────────────────────────────
dump.rdb

# ── Docker ────────────────────────────────────────────────────────────────────
# Keep docker-compose.yml and Dockerfile tracked
# Ignore local override files
docker-compose.override.yml
docker-compose.local.yml
.docker/

# ── Type checkers ────────────────────────────────────────────────────────────
.pyre/
.pyre_configuration
pyrightconfig.json
.mypy_cache/
.dmypy.json
dmypy.json

# ── Testing & Coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
nosetests.xml
test-results/

# ── IDE & Editors ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject

# ── OS generated ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Windows scripts (local dev helpers, not needed in repo) ──────────────────
allow_firewall.bat
run_https.bat
start_network.bat
start_ngrok.bat

# ── Ngrok / tunnel configs ────────────────────────────────────────────────────
ngrok.yml
.ngrok2/

# ── Archive / scratch ─────────────────────────────────────────────────────────
_archive/

# ── Recordings & video output ─────────────────────────────────────────────────
recordings/
*.mp4
*.avi
*.mkv
*.mov

# ── Face / ML model cache ─────────────────────────────────────────────────────
*.dat
*.pkl
*.pickle
models/
.dlib/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Node (camera_service or any frontend tooling) ────────────────────────────
node_modules/
npm-debug.log*
yarn-error.log*

# ── Misc ──────────────────────────────────────────────────────────────────────
*.bak
*.tmp
*.orig
setup_admin.py
