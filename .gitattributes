# Force LF line endings for shell scripts (so they work on Linux after clone)
*.sh text eol=lf

# Force LF for all text files
*.py text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.conf text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf

# Binary files — no line ending conversion
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.ico binary
*.svg binary
*.mp4 binary
*.avi binary
*.pkl binary
*.xlsx binary
