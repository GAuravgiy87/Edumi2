# ─────────────────────────────────────────────────────────────────────────────
# Edumi — Environment Variables
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# Django
SECRET_KEY=your-secret-key-here-change-this
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,*

# Redis — required for WebSocket (Django Channels) and Celery
# Local:         redis://localhost:6379/0
# Docker:        redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0

# PostgreSQL — optional, falls back to SQLite if not set
# Local:         postgresql://edumi:edumi_secret@localhost:5432/edumi
# Docker:        set via DATABASE_URL in docker-compose.yml
# DATABASE_URL=postgresql://edumi:edumi_secret@localhost:5432/edumi
POSTGRES_DB=edumi
POSTGRES_USER=edumi
POSTGRES_PASSWORD=edumi_secret

# Camera Service URL
# Local:         http://localhost:8001   (auto-managed by CamerasConfig.ready())
# Docker:        http://camera_service:8001
CAMERA_SERVICE_URL=http://localhost:8001

# LiveKit SFU
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret_must_be_32_characters_long_1234

# Face recognition
FACE_ENCRYPTION_KEY=
FACE_MATCH_THRESHOLD=0.50
FACE_PRESENCE_DURATION=30
