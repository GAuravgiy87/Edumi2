# Copy this to .env and fill in values

SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,*

# Redis (required for multi-process channel layers)
REDIS_URL=redis://localhost:6379/0

# LiveKit SFU
# Local dev: run  docker run --rm -p 7880:7880 -p 7881:7881 -p 50000-50200:50000-50200/udp \
#   -v $(pwd)/livekit.yaml:/etc/livekit/config.yaml livekit/livekit-server --config /etc/livekit/config.yaml
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# For production — use a strong secret (32+ chars) and your server's public address
# LIVEKIT_URL=wss://your-livekit-server.com
# LIVEKIT_API_KEY=your-api-key
# LIVEKIT_API_SECRET=your-very-long-secret-at-least-32-chars
