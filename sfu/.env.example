# SFU server config
SFU_PORT=3000
# Announced IP — set to your server's public IP in production
# In Docker this is set via environment variable
ANNOUNCED_IP=127.0.0.1
# UDP port range for WebRTC media (must match Docker port mapping)
RTC_MIN_PORT=40000
RTC_MAX_PORT=40100
# Shared secret with Django for request auth
SFU_SECRET=change-me-in-production
# Number of mediasoup workers (default: CPU count)
NUM_WORKERS=
